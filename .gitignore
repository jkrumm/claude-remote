# Node / Bun
node_modules/
dist/
bun.lock
# Track api/ lockfile for reproducible Docker builds
!api/bun.lock
# nanoclaw local state (created at runtime by Docker)
nanoclaw/store/
nanoclaw/groups/*
!nanoclaw/groups/global/
nanoclaw/groups/global/*
!nanoclaw/groups/global/CLAUDE.md
!nanoclaw/groups/main/
nanoclaw/groups/main/*
!nanoclaw/groups/main/CLAUDE.md
!nanoclaw/groups/telegram_main/
nanoclaw/groups/telegram_main/*
!nanoclaw/groups/telegram_main/CLAUDE.md
nanoclaw/logs/

# Secrets (never commit)
.env
.env.*
!.env.example

# OS
.DS_Store
*.swp
*.swo
Thumbs.db
